# === Обязательно поменять под заказчика ===
DOMAIN=cards.example.ru
ACME_EMAIL=admin@example.ru

# === Секреты: install.sh сгенерирует автоматически, если оставить CHANGE_ME ===
POSTGRES_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME

# Первый супер-админ (создаётся при первом старте)
SEED_SUPER_ADMIN_EMAIL=admin@stdrf.ru
SEED_SUPER_ADMIN_PASSWORD=CHANGE_ME

# === Образы (грузятся из images/*.tar при установке) ===
API_IMAGE=std-cards-api:prod
FRONTEND_IMAGE=std-cards-frontend:prod

# === Почта (сброс пароля). Пусто = письма отключены, форма «Забыли пароль» не работает ===
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SSL=true

# === Опционально ===
LOG_LEVEL=INFO
SENTRY_DSN=

# Каталог для бэкапов БД. По умолчанию ./backups рядом с установкой.
# Для бэкапов на отдельный диск: sudo ./setup-backup-disk.sh /dev/sdX — пропишет сюда путь.
BACKUP_DIR=./backups
